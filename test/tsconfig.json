{
  "compilerOptions": {
    "target": "es6",
    "module": "commonjs",
    "lib": [
      "es6"
    ],
    "rootDir": "../",
    "strict": false,
    "esModuleInterop": true,
    "noImplicitAny": false,
    "removeComments": true,
    "sourceMap": true,
    "baseUrl": "../",
    "paths": {
      "*": ["*", "node_modules/*"]
    },
    "types": ["node", "mocha", "sinon"]
  },
  "include": [
    "**/*",
    "../src/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}